# ============================================================
# QUARTZIQ REVIEW EXTRACTION - ENVIRONMENT CONFIGURATION
# ============================================================

# ------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL) - NEW! 🚀
# ------------------------------------------------------------

# PostgreSQL Connection (Supabase, Neon, Railway, or local)
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_PORT=5432
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here

# Alternative: Connection String (if your provider gives you one)
# DATABASE_URL=postgresql://postgres:password@host:5432/database

# ------------------------------------------------------------
# API INTEGRATIONS
# ------------------------------------------------------------

# Apify API Configuration (Required for Google Maps & Reviews)
APIFY_API_TOKEN=your_apify_api_token_here

# Google Places API Configuration
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Backend Configuration
BACKEND_EXTRACTOR_PATH=/path/to/universal-business-review-extractor.js

# Firecrawl API Configuration (for contact extraction)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Claude API Configuration (for website research during enrichment)
# Get your API key from: https://console.anthropic.com/
# This is optional - if not provided, will skip free Claude research and go straight to Apollo
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Apollo.io API Configuration (for contact enrichment)
# Get your API key from: https://apollo.io/settings/integrations
APOLLO_API_KEY=your_apollo_api_key_here

# Apollo API Monthly Limit (default: 100 for free tier)
# Increase this value if you're on a paid plan
APOLLO_MONTHLY_LIMIT=100

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3069
PORT=3069

# NextAuth.js Configuration (Authentication)
# Generate a secret with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
NEXTAUTH_URL=http://localhost:3069
AUTH_TRUST_HOST=true

# Cron Job Security (for automated monitoring)
# Generate a secret with: openssl rand -base64 32
# This protects your cron endpoints from unauthorized access
CRON_SECRET=your_cron_secret_here

# GoHighLevel (GHL) Configuration - Default Client
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
GHL_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-webhook-url

# GHL Webhook Security (for inbound webhooks from GHL)
# Generate a secret with: openssl rand -base64 32
# This protects your webhook endpoints from unauthorized access
GHL_WEBHOOK_SECRET=your_ghl_webhook_secret_here

# GHL Custom Field Mappings (Optional - for custom fields in GHL)
GHL_FIELD_COMPANY_NAME=custom_field_company_name_id
GHL_FIELD_WEBSITE=custom_field_website_id
GHL_FIELD_GOOGLE_URL=custom_field_google_url_id
GHL_FIELD_NICHE_CATEGORY=custom_field_niche_category_id
GHL_FIELD_REVIEW_DATE=custom_field_review_date_id
GHL_FIELD_REVIEW_STARS=custom_field_review_stars_id
GHL_FIELD_QUALIFIED_REVIEWS_CONTENT=custom_field_qualified_reviews_content_id
GHL_FIELD_QUALIFIED_REVIEW_URL=custom_field_qualified_review_url_id
GHL_FIELD_GOOGLE_QUALIFIED_REVIEWS=custom_field_google_qualified_reviews_id
GHL_FIELD_REVIEW_IMAGE_URL=custom_field_review_image_url_id
