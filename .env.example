# ============================================================
# QUARTZIQ REVIEW EXTRACTION - ENVIRONMENT CONFIGURATION
# ============================================================

# ------------------------------------------------------------
# DATABASE CONFIGURATION (PostgreSQL) - NEW! 🚀
# ------------------------------------------------------------

# PostgreSQL Connection (Supabase, Neon, Railway, or local)
POSTGRES_HOST=db.your-project.supabase.co
POSTGRES_PORT=5432
POSTGRES_DATABASE=postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your-strong-password-here

# Alternative: Connection String (if your provider gives you one)
# DATABASE_URL=postgresql://postgres:password@host:5432/database

# ------------------------------------------------------------
# API INTEGRATIONS
# ------------------------------------------------------------

# Apify API Configuration (Required for Google Maps & Reviews)
APIFY_API_TOKEN=your_apify_api_token_here

# Google Places API Configuration
GOOGLE_PLACES_API_KEY=your_google_places_api_key_here

# Backend Configuration
BACKEND_EXTRACTOR_PATH=/path/to/universal-business-review-extractor.js

# Firecrawl API Configuration (for contact extraction)
FIRECRAWL_API_KEY=your_firecrawl_api_key_here

# Apollo.io API Configuration (for contact enrichment)
# Get your API key from: https://apollo.io/settings/integrations
APOLLO_API_KEY=your_apollo_api_key_here

# Apollo API Monthly Limit (default: 100 for free tier)
# Increase this value if you're on a paid plan
APOLLO_MONTHLY_LIMIT=100

# Next.js Configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
PORT=3000

# GoHighLevel (GHL) Configuration - Default Client
GHL_API_KEY=your_ghl_api_key_here
GHL_LOCATION_ID=your_ghl_location_id_here
GHL_WEBHOOK_URL=https://hooks.zapier.com/hooks/catch/your-webhook-url

# GHL Custom Field Mappings
GHL_FIELD_BUSINESS_NAME=custom_field_business_name_id
GHL_FIELD_REVIEW_RATING=custom_field_review_rating_id
GHL_FIELD_REVIEW_TEXT=custom_field_review_text_id
GHL_FIELD_BUSINESS_CATEGORY=custom_field_business_category_id
GHL_FIELD_REVIEW_DATE=custom_field_review_date_id

# Airtable Configuration
# Get your API key from: https://airtable.com/create/tokens
AIRTABLE_API_KEY=your_airtable_api_key_here

# Find your Base ID in the Airtable API documentation for your base
# Format: appXXXXXXXXXXXXXX
AIRTABLE_BASE_ID=your_airtable_base_id_here

# The name of the table where leads will be added (default: "Leads")
AIRTABLE_TABLE_NAME=Leads
