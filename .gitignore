# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# ============================================
# PROJECT-SPECIFIC PATTERNS
# ============================================

# Development notes and session documentation
/*-COMPLETE.md
/*-SUMMARY.md
/*-STATUS.md
/*-FIX.md
/*-GUIDE.md
/*-ANALYSIS.md
/*-REPORT.md
/BUG-*.md
/DEPLOYMENT-*.md
/IMPLEMENTATION-*.md
/SESSION-*.md
/TIMELINE-*.md

# Data files (backups, exports, test data)
/*.csv
/*.json
!package.json
!package-lock.json
!tsconfig.json
/backup-*
/apify-dataset-*
/data/apify-backup-*
/data/apify-imports/
/data/backups/
/data/extraction-history/*.json
/data/scraped-businesses.json
/data/businesses-import.csv
/data/extraction-results.json
/data/place-ids-*.txt
/data/place-ids-*.json
/data/*.log

# Backup and temporary files
*.backup
*.old
*-OPTION*.ts
*-OPTION*.js

# Database utilities and test scripts
/database/test-*.js
/database/import-*.js
/database/create-*.js

# Root-level utility scripts (should be in /scripts/)
/test-*.js
/check-*.js
/create-*.js
/import-*.js
/resume-*.js
/retrieve-*.js

# Keep essential docs
!README.md
!CONTRIBUTING.md
!CHANGELOG.md
!LICENSE.md
!CLAUDE.md
